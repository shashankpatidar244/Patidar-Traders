generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  isVerified    Boolean        @default(false)
  password      String?
  phone         String         @unique
  pendingPhone  String?
  username      String?
  role          Role           @default(USER)
  otp           String?
  otpExpiresAt  DateTime?
  isBlocked     Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  addresses     Address[]
  cartItem      CartItem[]
  inventoryLogs InventoryLog[]
  orders        Order[]
  refreshTokens RefreshToken[]
  wishlistItems WishlistItem[]

  @@index([createdAt])
}

model AdminLog {
  id        Int      @id @default(autoincrement())
  action    String
  entity    String
  entityId  Int
  createdAt DateTime @default(now())
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Brand {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@index([name])
}

model Product {
  id          Int     @id @default(autoincrement())
  name        String
  description String?

  technicalName String? @db.VarChar(255)
  brandId       Int?

  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  categoryId Int?

  cartItem      CartItem[]
  orderItems    OrderItem[]
  category      Category?        @relation(fields: [categoryId], references: [id])
  brand         Brand?           @relation(fields: [brandId], references: [id])
  images        ProductImage[]
  variants      ProductVariant[]
  wishlistItems WishlistItem[]

  @@index([technicalName])
  @@index([brandId])
  @@index([categoryId])
  @@index([name, technicalName])
}

model ProductVariant {
  id        Int    @id @default(autoincrement())
  productId Int
  name      String
  value     String

  mrp          Float?
  sellingPrice Float?

  unit      Unit?
  stock     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cartItems     CartItem[]
  inventoryLogs InventoryLog[]
  orderItems    OrderItem[]
  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  wishlistItems WishlistItem[]

  @@index([productId])
  @@index([sellingPrice])
  @@index([mrp])
  @@index([productId, sellingPrice])
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  url       String
  productId Int
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model InventoryLog {
  id        Int             @id @default(autoincrement())
  variantId Int
  oldStock  Int
  newStock  Int
  action    InventoryAction
  adminId   Int?
  createdAt DateTime        @default(now())
  admin     User?           @relation(fields: [adminId], references: [id])
  variant   ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([createdAt])
}

model Order {
  id     Int @id @default(autoincrement())
  userId Int

  total Decimal @db.Decimal(10, 2)

  status OrderStatus @default(PENDING)

  paymentMethod PaymentMethod @default(COD)
  paymentStatus PaymentStatus @default(PENDING)

  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  paidAt            DateTime?
  expiresAt         DateTime?

  deliveryStatus DeliveryStatus @default(PENDING)
  trackingId     String?

  shippingName    String
  shippingPhone   String
  shippingLine1   String
  shippingLine2   String?
  shippingCity    String
  shippingState   String
  shippingPincode String

  selectedCartIds Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model OrderItem {
  id        Int  @id @default(autoincrement())
  orderId   Int
  productId Int
  variantId Int?

  quantity Int
  price    Decimal @db.Decimal(10, 2)

  order   Order           @relation(fields: [orderId], references: [id])
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
}

model PaymentWebhookEvent {
  id Int @id @default(autoincrement())

  eventId   String @unique
  eventType String

  createdAt DateTime @default(now())

  @@index([createdAt])
}

model CartItem {
  id        Int             @id @default(autoincrement())
  userId    Int
  productId Int
  variantId Int?
  quantity  Int             @default(1)
  createdAt DateTime        @default(now())
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([userId, productId, variantId])
}

model WishlistItem {
  id        Int            @id @default(autoincrement())
  userId    Int
  productId Int
  variantId Int
  createdAt DateTime       @default(now())
  product   Product        @relation(fields: [productId], references: [id])
  user      User           @relation(fields: [userId], references: [id])
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([userId, productId, variantId])
}

model Address {
  id        Int         @id @default(autoincrement())
  userId    Int
  fullName  String
  phone     String
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  type      AddressType @default(HOME)
  isDefault Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id])
}

enum Role {
  ADMIN
  USER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  COD
  UPI
  CARD
}

enum DeliveryStatus {
  PENDING
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
}

enum Unit {
  GM
  KG
  ML
  L
  PCS
}

enum InventoryAction {
  ADD
  REDUCE
  SET
}

enum AddressType {
  HOME
  WORK
  OTHER
}
